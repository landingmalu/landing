---
import Layout from '../layouts/Layout.astro';

// Obtener parámetros de la URL
const urlParams = new URL(Astro.request.url).searchParams;
const amount = urlParams.get('amount') || '0';
const buyOrder = urlParams.get('buyOrder') || '';
const authCode = urlParams.get('authCode') || '';

// Formatear monto
const formattedAmount = new Intl.NumberFormat('es-CL', {
  style: 'currency',
  currency: 'CLP'
}).format(parseInt(amount));
---

<Layout>
  <main class="min-h-screen w-full bg-white">
    <!-- Header Section -->
    <div class="bg-[#989086] py-2 md:py-3">
      <div class="text-center">
        <h1 class="text-3xl md:text-4xl tracking-[0.4em] font-light text-white mb-0">PILATES</h1>
        <p class="text-xs md:text-sm tracking-[0.4em] font-light text-white mt-0">MALÚ PÉREZ</p>
      </div>
    </div>

    <!-- Contenido de éxito -->
    <section class="w-full flex flex-col items-center justify-center py-16 px-4">
      <div class="max-w-2xl w-full bg-[#EDE8E3] rounded-3xl shadow-lg p-8 md:p-12 text-center">
        <!-- Icono de éxito -->
        <div class="mb-6">
          <svg class="w-20 h-20 mx-auto text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold text-[#989086] mb-4">¡Pago Exitoso!</h2>
        <p class="text-lg text-[#989086] mb-8">Tu compra ha sido procesada correctamente.</p>

        <!-- Detalles de la transacción -->
        <div class="bg-white rounded-xl p-6 mb-8 text-left">
          <h3 class="text-xl font-bold text-[#989086] mb-4">Detalles de la Transacción</h3>
          <div class="space-y-3">
            <div class="flex justify-between border-b border-[#DFD9D0] pb-2">
              <span class="text-[#989086] font-semibold">Monto:</span>
              <span class="text-[#989086]">{formattedAmount}</span>
            </div>
            <div class="flex justify-between border-b border-[#DFD9D0] pb-2">
              <span class="text-[#989086] font-semibold">Orden de Compra:</span>
              <span class="text-[#989086] font-mono text-sm">{buyOrder}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-[#989086] font-semibold">Código de Autorización:</span>
              <span class="text-[#989086] font-mono text-sm">{authCode}</span>
            </div>
          </div>
        </div>

        <!-- Información adicional -->
        <div class="bg-[#D4CCC3] rounded-xl p-6 mb-8">
          <p class="text-[#989086] text-sm">
            Recibirás un correo electrónico con los detalles de tu compra y las instrucciones para acceder a tus clases.
          </p>
        </div>

        <!-- Botón volver -->
        <a href="/" class="inline-block bg-[#989086] text-white font-bold text-lg px-10 py-3 rounded-full hover:bg-[#B4A79D] transition">
          Volver al Inicio
        </a>
      </div>
    </section>
  </main>
</Layout>
