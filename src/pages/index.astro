---
import Layout from '../layouts/Layout.astro';
import LagreeFitness from '../components/LagreeFitness.astro';

const CUPOS_MAXIMOS = Number(import.meta.env.PUBLIC_CUPOS_MAX) || 20;
---

<Layout>
	<main class="min-h-screen w-full" data-cupos-max={CUPOS_MAXIMOS}>
		<script>
			// Redirigir a la página de compra
			function handleCompra() {
				window.location.href = '/comprar';
			}

			// Verificar cupos disponibles
			async function checkCuposDisponibles() {
				try {
					const response = await fetch('/api/clientes/count');
					const data = await response.json();
					const cuposOcupados = data.count || 0;
					const cuposMaximos = Number(document.querySelector('main')?.getAttribute('data-cupos-max')) || 20;
					const cuposDisponibles = cuposMaximos - cuposOcupados;

					const alertElement = document.getElementById('cupos-llenos-alert');
					const button = document.getElementById('btn-comprar');

					if (cuposDisponibles <= 0) {
						if (alertElement) {
							alertElement.classList.remove('hidden');
						}
						if (button) {
							button.setAttribute('disabled', 'true');
							button.classList.add('line-through', 'opacity-60', 'cursor-not-allowed');
							button.textContent = 'CUPOS COMPLETOS';
						}
					} else {
						if (alertElement) {
							alertElement.classList.add('hidden');
						}
						if (button) {
							button.removeAttribute('disabled');
							button.classList.remove('line-through', 'opacity-60', 'cursor-not-allowed');
							button.textContent = 'COMPRAR';
						}
					}
				} catch (error) {
					console.error('Error verificando cupos:', error);
				}
			}

			// Agregar evento al botón cuando el DOM esté listo
			document.addEventListener('DOMContentLoaded', () => {
				const button = document.getElementById('btn-comprar');
				if (button) {
					button.addEventListener('click', handleCompra);
				}

				checkCuposDisponibles();
			});
		</script>
			<!-- Header Section with Logo -->
			<div class="bg-[#989086] h-20 md:h-28 flex items-center justify-center overflow-hidden">
				<img src="/fonts/Logo-Malu-Perez-Final.png" alt="Malú Pérez Pilates" class="h-32 md:h-56 w-auto object-contain" />
			</div>

			<!-- Hero Section with Background Image (imagen responsiva, siempre visible) -->
			<section class="relative w-full">
				<div class="w-full hero-wrapper">
					<img src="/fonts/Copia de logo malu perez mas lagree.jpg" alt="Hero" class="w-full block object-contain h-auto object-center" />
				</div>

				<!-- Franja "PREVENTA EXCLUSIVA" ubicada inmediatamente debajo de la imagen -->
				<div class="w-full">
					<div class="bg-[#EDE8E3] py-6">
						<div class="text-center">
							<h3 class="text-xl md:text-2xl lg:text-3xl tracking-[0.2em] font-bold text-[#989086] uppercase">PREVENTA EXCLUSIVA SOLO 20 CUPOS</h3>
						</div>
					</div>
				</div>
			</section>

		<!-- Segunda sección: Pack Trimestral -->
		<section class="bg-white w-full flex flex-col items-center py-8 md:py-12 px-2">
				<div class="w-full flex flex-col items-center">
					<div class="bg-[#DFD9D0] rounded-3xl shadow-md px-4 py-8 md:px-8 md:py-10 max-w-xl w-full flex flex-col items-center">
					<span class="bg-[#8B7E74] text-white text-base md:text-lg font-semibold px-4 md:px-6 py-2 rounded-full mb-4">PACK TRIMESTRAL</span>
					<div class="text-[#989086] text-3xl md:text-5xl font-bold mb-2">$369.990</div>
					<div class="text-[#989086] text-sm md:text-base font-light mb-4">($133.330 x mes)</div>
					<div class="text-[#989086] text-base md:text-lg font-semibold mb-2">Incluye</div>
					<ul class="text-[#989086] text-sm md:text-base font-light mb-6 text-center">
						<li>36 clases</li>
						<li>Vigencia 90 días</li>
						<li>Estacionamiento liberado 1 hora</li>
					</ul>

					</div>
					<div class="mt-6 flex flex-col items-center">
						<button id="btn-comprar" class="bg-[#989086] text-white font-bold text-base md:text-lg px-6 md:px-10 py-2 rounded-full hover:bg-[#B4A79D] transition disabled:opacity-50 disabled:cursor-not-allowed">COMPRAR</button>
						<div id="cupos-llenos-alert" class="hidden mt-4 text-red-600 text-center">
							<span class="font-bold">¡Ya se llenaron los cupos disponibles!</span>
						</div>
					</div>
				</div>
		</section>

		<!-- Barra informativa -->
		<section class="bg-[#A1998D] w-full py-6">
			<div class="text-center">
				<span class="text-white text-xl md:text-2xl font-bold">Puedes combinar PILATES REFORMER con el revolucionario método LAGREE FITNESS</span>
			</div>
		</section>

		<!-- Sección descriptiva Lagree y Pilates -->
		<section class="w-full bg-white">
			<div class="max-w-7xl mx-auto grid grid-cols-2 gap-0 two-col-grid">
				<!-- Texto Lagree Fitness -->
				<div class="col-span-1 p-4 md:p-8 flex items-center">
					<p class="text-[#989086] text-sm md:text-lg font-light leading-relaxed"><span class="font-bold">Lagree Fitness</span>, uno de los métodos de entrenamiento más exigentes y comentados del momento, llega por primera vez a Chile. Este entrenamiento de alta intensidad y bajo impacto combina fuerza, resistencia, control y un trabajo profundo de core. Se realiza sobre el Megaformer, mediante movimientos lentos y precisos que mantienen el músculo bajo tensión constante, maximizando los resultados en cada sesión. Favorito de celebridades en Hollywood, abrimos el primer estudio oficial de Lagree en Chile, con clases desafiantes, eficientes y conscientes.</p>
				</div>
				<!-- Imagen Lagree Fitness Megaformer -->
				<div class="col-span-1 w-full h-full flex items-center justify-center">
					<img src="/fonts/ChatGPT Image Feb 9, 2026 at 11_00_23 AM.png" alt="Lagree Fitness" class="object-cover w-full h-48 sm:h-72 md:h-96" />
				</div>
			</div>
			<div class="max-w-7xl mx-auto grid grid-cols-2 gap-0 two-col-grid">
				<!-- Imagen Pilates Reformer -->
				<div class="col-span-1 w-full h-full flex items-center justify-center">
					<img src="/fonts/ChatGPT Image Feb 10, 2026 at 11_35_18 AM.png" alt="Pilates Reformer" class="object-cover w-full h-48 sm:h-72 md:h-96" />
				</div>
				<!-- Texto Pilates Reformer -->
				<div class="col-span-1 p-4 md:p-8 flex items-center">
					<p class="text-[#989086] text-sm md:text-lg font-light leading-relaxed"><span class="font-bold">Pilates Reformer</span> es un entrenamiento de bajo impacto que fortalece, tonifica y alarga el cuerpo de forma integral. Mejora la postura, la flexibilidad y la estabilidad del core a través de movimientos controlados y precisos. Ideal para todos los niveles y para quienes buscan fuerza, equilibrio y conexión cuerpo–mente.</p>
				</div>
			</div>
		</section>

		<!-- Barra HORARIOS -->
		<section class="bg-[#A1998D] w-full py-6">
			<div class="text-center">
				<span class="text-white text-xl md:text-2xl font-bold">HORARIOS</span>
			</div>
		</section>

		<!-- Horarios con imágenes -->
		<section class="w-full bg-white py-8 md:py-12 flex flex-col items-center px-4 gap-8">
			<!-- Horario Sala 1 -->
			<div class="w-full max-w-6xl">
				<img 
					src="/fonts/Screenshot 2026-02-24 at 18.47.57.png" 
					alt="Horarios Sala 1 - Reformer" 
					class="w-full h-auto object-contain"
				/>
			</div>

			<!-- Horario Sala 2 -->
			<div class="w-full max-w-6xl">
				<img 
					src="/fonts/Screenshot 2026-02-24 at 18.48.10.png" 
					alt="Horarios Sala 2 - Lagree Fitness" 
					class="w-full h-auto object-contain"
				/>
			</div>
		</section>

			 <!-- Footer Section -->
			 <footer class="bg-[#A1998D] w-full py-3 md:py-10">
				 <div class="w-full px-1 md:px-4">
					 <div class="flex flex-row items-center justify-between flex-nowrap gap-1 md:gap-8">
						 <!-- Logo -->
						 <div class="flex-shrink-0 flex items-center justify-center">
							 <img src="/fonts/Logo-Malu-Perez-Final-Footer.png" alt="Malú Pérez" class="h-14 md:h-24 w-14 md:w-24 object-contain rounded-full bg-[#A1998D] p-1 md:p-2 border-0" />
						 </div>
						 <!-- Instagram -->
						 <div class="flex flex-col items-center flex-grow text-center min-w-0">
							 <svg class="w-5 md:w-12 h-5 md:h-12 text-white mb-0.5 md:mb-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								 <rect width="20" height="20" x="2" y="2" rx="5" stroke="currentColor" stroke-width="2"/>
								 <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
								 <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>
							 </svg>
							 <span class="text-white font-light text-[10px] md:text-base leading-none">Síguenos en</span>
							 <span class="text-white font-semibold text-[9px] md:text-base leading-none">@pilatesmaluperez</span>
						 </div>

						 <!-- Location -->
						 <div class="flex flex-col items-end flex-shrink-0 text-right min-w-0">
							 <svg class="w-5 md:w-12 h-5 md:h-12 text-white mb-0.5 md:mb-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
								 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
							 </svg>
							 <span class="text-white font-light text-[9px] md:text-base leading-none">Mall Casa</span>
							 <span class="text-white font-light text-[9px] md:text-base leading-none">Costanera</span>
							 <span class="text-white font-light text-[9px] md:text-base leading-none">Vitacura</span>
						 </div>
					 </div>
				 </div>
			 </footer>
	</main>
</Layout>
