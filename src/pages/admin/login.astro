---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen w-full bg-white">
    <!-- Header -->
    <div class="bg-[#989086] h-20 md:h-28 flex items-center justify-center overflow-hidden">
      <img src="/fonts/Logo-Malu-Perez-Final.png" alt="Malú Pérez Pilates" class="h-32 md:h-56 w-auto object-contain" />
    </div>

    <!-- Título -->
    <div class="w-full bg-transparent py-12">
      <h1 class="text-center text-[#8B7E74] text-4xl md:text-5xl font-bold italic">ADMINISTRACIÓN</h1>
    </div>

    <!-- Formulario de Login -->
    <div class="bg-white py-12 px-4">
      <div class="max-w-md mx-auto">
        <div class="bg-[#EDE8E3] rounded-3xl shadow-lg p-8">
          <h2 class="text-2xl font-bold text-[#989086] mb-6 text-center">Iniciar Sesión</h2>
          
          <form id="login-form" class="space-y-6">
            <!-- Usuario -->
            <div>
              <label for="username" class="block text-[#989086] font-semibold mb-2">Usuario</label>
              <input
                type="text"
                id="username"
                name="username"
                class="w-full px-4 py-3 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                placeholder="Usuario"
                required
              />
            </div>

            <!-- Contraseña -->
            <div>
              <label for="password" class="block text-[#989086] font-semibold mb-2">Contraseña</label>
              <input
                type="password"
                id="password"
                name="password"
                class="w-full px-4 py-3 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                placeholder="Contraseña"
                required
              />
            </div>

            <!-- Error message -->
            <div id="error-message" class="hidden bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
              Usuario o contraseña incorrectos
            </div>

            <!-- Botón -->
            <button
              type="submit"
              class="w-full bg-[#989086] text-white font-bold text-lg py-3 rounded-full hover:bg-[#B4A79D] transition"
            >
              INGRESAR
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  document.getElementById('login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const username = formData.get('username');
    const password = formData.get('password');
    const errorMessage = document.getElementById('error-message');

    try {
      const response = await fetch('/api/admin/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password })
      });

      const result = await response.json();

      if (result.success) {
        // Guardar token en sessionStorage
        sessionStorage.setItem('admin_token', result.token);
        // Redirigir al dashboard
        window.location.href = '/admin/dashboard';
      } else {
        errorMessage?.classList.remove('hidden');
      }
    } catch (error) {
      console.error('Error al iniciar sesión:', error);
      errorMessage?.classList.remove('hidden');
    }
  });
</script>
