---
import Layout from '../layouts/Layout.astro';

const PACK_MENSUAL = 50;
const PACK_TRIMESTRAL = 50;
---

<Layout>
  <main class="min-h-screen w-full bg-white">
    <!-- Header -->
    <div class="bg-[#989086] h-20 md:h-28 flex items-center justify-center overflow-hidden">
      <img src="/fonts/Logo-Malu-Perez-Final.png" alt="Malú Pérez Pilates" class="h-32 md:h-56 w-auto object-contain" />
    </div>

    <!-- Título -->
    <div class="w-full bg-transparent py-12">
      <h1 class="text-center text-[#8B7E74] text-4xl md:text-5xl font-bold italic">FINALIZAR COMPRA</h1>
    </div>

    <!-- Progress Bar -->
    <div class="bg-white py-8 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <div class="flex flex-col items-center flex-1">
            <div class="w-10 h-10 bg-[#989086] text-white rounded-full flex items-center justify-center font-bold mb-2">1</div>
            <span class="text-[#989086] font-semibold text-sm">Detalles</span>
          </div>
          <div class="flex-1 h-1 bg-[#989086] mx-4 mb-6"></div>
          <div class="flex flex-col items-center flex-1">
            <div class="w-10 h-10 bg-[#989086] text-white rounded-full flex items-center justify-center font-bold mb-2">2</div>
            <span class="text-[#989086] font-semibold text-sm">Pago</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="bg-white py-12 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col lg:flex-row gap-8">
          <!-- Formulario -->
          <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold text-[#989086] mb-8">Detalles De Facturación</h2>

            <form id="checkout-form" class="space-y-6">
              <!-- Nombre y Apellidos -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="nombre" class="block text-[#989086] font-semibold mb-2">Nombre *</label>
                  <input
                    type="text"
                    id="nombre"
                    name="nombre"
                    class="w-full px-4 py-2 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                    placeholder="Nombre"
                  />
                  <div id="error-nombre" class="text-red-500 text-sm mt-1 hidden">Por favor, completa el campo Nombre</div>
                </div>
                <div>
                  <label for="apellidos" class="block text-[#989086] font-semibold mb-2">Apellidos *</label>
                  <input
                    type="text"
                    id="apellidos"
                    name="apellidos"
                    class="w-full px-4 py-2 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                    placeholder="Apellidos"
                  />
                  <div id="error-apellidos" class="text-red-500 text-sm mt-1 hidden">Por favor, completa el campo Apellidos</div>
                </div>
              </div>

              <!-- Email y Teléfono -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="email" class="block text-[#989086] font-semibold mb-2">Dirección de correo electrónico *</label>
                  <input
                    type="text"
                    id="email"
                    name="email"
                    class="w-full px-4 py-2 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                    placeholder="tu@email.com"
                  />
                  <div id="error-email" class="text-red-500 text-sm mt-1 hidden">Por favor, completa el campo Email</div>
                </div>
                <div>
                  <label for="telefono" class="block text-[#989086] font-semibold mb-2">Teléfono *</label>
                  <input
                    type="text"
                    id="telefono"
                    name="telefono"
                    class="w-full px-4 py-2 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                    placeholder="+56 9 1234 5678"
                  />
                  <div id="error-telefono" class="text-red-500 text-sm mt-1 hidden">Por favor, completa el campo Teléfono</div>
                </div>
              </div>

              <!-- Divider -->
              <hr class="border-[#D4CCC3]" />

              <!-- Dirección -->
              <div>
                <label for="pais" class="block text-[#989086] font-semibold mb-2">País / Región *</label>
                <input
                  type="text"
                  id="pais"
                  name="pais"
                  class="w-full px-4 py-2 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                  placeholder="País"
                />
                <div id="error-pais" class="text-red-500 text-sm mt-1 hidden">Por favor, completa el campo País</div>
              </div>

              <div>
                <label for="direccion" class="block text-[#989086] font-semibold mb-2">Dirección de la calle *</label>
                <input
                  type="text"
                  id="direccion"
                  name="direccion"
                  class="w-full px-4 py-2 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                  placeholder="Nombre de la calle y número de la casa"
                />
                <div id="error-direccion" class="text-red-500 text-sm mt-1 hidden">Por favor, completa el campo Dirección</div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="ciudad" class="block text-[#989086] font-semibold mb-2">Población / Ciudad *</label>
                  <input
                    type="text"
                    id="ciudad"
                    name="ciudad"
                    class="w-full px-4 py-2 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                    placeholder="Tu ciudad"
                  />
                  <div id="error-ciudad" class="text-red-500 text-sm mt-1 hidden">Por favor, completa el campo Ciudad</div>
                </div>
                <div>
                  <label for="region" class="block text-[#989086] font-semibold mb-2">Región *</label>
                  <input
                    type="text"
                    id="region"
                    name="region"
                    class="w-full px-4 py-2 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                    placeholder="Región"
                  />
                  <div id="error-region" class="text-red-500 text-sm mt-1 hidden">Por favor, completa el campo Región</div>
                </div>
              </div>

              {/* Notas */}
              <div>
                <label for="notas" class="block text-[#989086] font-semibold mb-2">Notas del pedido (opcional)</label>
                <textarea
                  id="notas"
                  name="notas"
                  class="w-full px-4 py-2 border border-[#D4CCC3] rounded-lg focus:outline-none focus:border-[#989086]"
                  placeholder="Notas especiales para tu compra"
                  rows="4"
                ></textarea>
              </div>

              <!-- Términos y Condiciones -->
              <div class="pt-4">
                <div id="error-terminos" class="text-red-500 text-sm mb-2 hidden">Debes aceptar los términos y condiciones para continuar</div>
                <div class="flex items-start gap-3">
                  <input
                    type="checkbox"
                    id="terminos"
                    name="terminos"
                    class="w-5 h-5 text-[#989086] rounded cursor-pointer mt-1"
                  />
                  <label for="terminos" class="text-[#989086] text-sm">
                    Acepto los <button type="button" id="btn-terminos" class="text-[#989086] font-semibold underline hover:opacity-70">términos y condiciones</button>
                  </label>
                </div>
              </div>
            </form>
          </div>

          <!-- Resumen de Pedido -->
          <div class="w-full lg:w-96 flex-shrink-0">
            <div class="bg-[#8B7E74] text-white rounded-lg p-6 sticky top-6">
              <div class="mb-6">
                <div class="flex items-start gap-4 mb-4">
                  <img src="/fonts/Logo-Malu-Perez-Final-Footer.png" alt="Logo" class="w-20 h-20 object-contain flex-shrink-0" />
                  <div>
                    <h3 class="font-semibold text-lg">PACK TRIMESTRAL</h3>
                    <p class="text-sm opacity-90">x 1</p>
                  </div>
                </div>
                <div class="text-right">
                  <span class="text-2xl font-bold">${PACK_TRIMESTRAL.toLocaleString('es-CL')}</span>
                </div>
              </div>

              <div class="space-y-3 border-t border-[#A1998D] pt-4 mb-6">
                <div class="flex justify-between text-sm">
                  <span>Subtotal</span>
                  <span>${PACK_TRIMESTRAL.toLocaleString('es-CL')}</span>
                </div>
                <div class="flex justify-between text-lg font-semibold">
                  <span>Total</span>
                  <span>${PACK_TRIMESTRAL.toLocaleString('es-CL')}</span>
                </div>
              </div>

              <button
                id="btn-pagar"
                form="checkout-form"
                type="submit"
                class="w-full bg-[#DFD9D0] text-[#8B7E74] font-bold py-3 rounded-lg hover:bg-[#E8E4DF] transition disabled:opacity-50 disabled:cursor-not-allowed"
              >
                PROCEDER AL PAGO
              </button>

              <p class="text-xs text-center mt-4 opacity-75">
                Se te redirigirá a Transbank para completar el pago de forma segura
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Botón Volver al Inicio -->
    <div class="w-full bg-white py-8 px-4">
      <div class="max-w-4xl mx-auto flex justify-center">
        <a href="/" class="text-[#8B7E74] hover:text-[#989086] transition flex items-center gap-2 text-lg font-semibold border-2 border-[#8B7E74] hover:border-[#989086] px-6 py-3 rounded-lg">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver al inicio
        </a>
      </div>
    </div>

    <script>
      // Función para validar un campo
      function validateField(fieldId: string, errorId: string, customValidator?: (value: string) => boolean): boolean {
        const field = document.getElementById(fieldId) as HTMLInputElement;
        const error = document.getElementById(errorId) as HTMLElement;
        
        if (!field || !error) return true;
        
        const value = field.value.trim();
        let isValid = value !== '';
        
        if (customValidator) {
          isValid = isValid && customValidator(value);
        }
        
        if (!isValid) {
          error.classList.remove('hidden');
          field.classList.add('border-red-500');
        } else {
          error.classList.add('hidden');
          field.classList.remove('border-red-500');
        }
        
        return isValid;
      }

      // Validación de email
      function validateEmail(email: string): boolean {
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return emailRegex.test(email);
      }

      // Agregar listeners para validación en tiempo real
      document.addEventListener('DOMContentLoaded', () => {
        const fields = ['nombre', 'apellidos', 'email', 'telefono', 'pais', 'direccion', 'ciudad', 'region'];
        
        fields.forEach(fieldId => {
          const field = document.getElementById(fieldId) as HTMLInputElement;
          if (field) {
            field.addEventListener('blur', () => {
              if (fieldId === 'email') {
                const error = document.getElementById('error-email') as HTMLElement;
                if (error && field.value.trim() && !validateEmail(field.value.trim())) {
                  error.textContent = 'Por favor, ingresa un email válido';
                  error.classList.remove('hidden');
                  field.classList.add('border-red-500');
                } else if (error && field.value.trim() && validateEmail(field.value.trim())) {
                  error.classList.add('hidden');
                  field.classList.remove('border-red-500');
                }
              } else {
                validateField(fieldId, `error-${fieldId}`);
              }
            });
            
            field.addEventListener('input', () => {
              if (field.value.trim()) {
                const error = document.getElementById(`error-${fieldId}`) as HTMLElement;
                if (error) {
                  if (fieldId === 'email' && error.textContent === 'Por favor, ingresa un email válido') {
                    // Mantener el mensaje de formato inválido hasta que el usuario deje el campo
                  } else {
                    error.classList.add('hidden');
                    field.classList.remove('border-red-500');
                  }
                }
              }
            });
          }
        });
      });

      async function handleCheckout(e: Event) {
        e.preventDefault();
        const form = e.target as HTMLFormElement;
        const button = document.getElementById('btn-pagar') as HTMLButtonElement;
        const terminos = document.getElementById('terminos') as HTMLInputElement;
        const errorTerminos = document.getElementById('error-terminos') as HTMLElement;

        if (!button) return;

        // Validar todos los campos
        let isValid = true;
        
        isValid = validateField('nombre', 'error-nombre') && isValid;
        isValid = validateField('apellidos', 'error-apellidos') && isValid;
        isValid = validateField('telefono', 'error-telefono') && isValid;
        isValid = validateField('pais', 'error-pais') && isValid;
        isValid = validateField('direccion', 'error-direccion') && isValid;
        isValid = validateField('ciudad', 'error-ciudad') && isValid;
        isValid = validateField('region', 'error-region') && isValid;
        
        // Validar email con formato
        const emailField = document.getElementById('email') as HTMLInputElement;
        const emailError = document.getElementById('error-email') as HTMLElement;
        const emailValue = emailField.value.trim();
        
        if (!emailValue) {
          emailError.textContent = 'Por favor, completa el campo Email';
          emailError.classList.remove('hidden');
          emailField.classList.add('border-red-500');
          isValid = false;
        } else if (!validateEmail(emailValue)) {
          emailError.textContent = 'Por favor, ingresa un email válido';
          emailError.classList.remove('hidden');
          emailField.classList.add('border-red-500');
          isValid = false;
        } else {
          emailError.classList.add('hidden');
          emailField.classList.remove('border-red-500');
        }

        // Validar que aceptó los términos
        if (!terminos || !terminos.checked) {
          if (errorTerminos) {
            errorTerminos.classList.remove('hidden');
          }
          isValid = false;
        } else {
          if (errorTerminos) {
            errorTerminos.classList.add('hidden');
          }
        }

        if (!isValid) {
          return;
        }

        button.textContent = 'Procesando...';
        button.setAttribute('disabled', 'true');

        try {
          // Obtener datos del formulario
          const formData = new FormData(form);
          const clienteData = {
            nombre: formData.get('nombre'),
            apellidos: formData.get('apellidos'),
            email: formData.get('email'),
            telefono: formData.get('telefono'),
            pais: formData.get('pais'),
            region: formData.get('region'),
            ciudad: formData.get('ciudad'),
            direccion: formData.get('direccion'),
            notas: formData.get('notas'),
            monto: 50
          };

          // 1. Guardar cliente en BD
          const clienteResponse = await fetch('/api/cliente/crear', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(clienteData)
          });

          const clienteResult = await clienteResponse.json();

          if (!clienteResult.success) {
            throw new Error(clienteResult.error || 'Error al guardar datos');
          }

          const clienteId = clienteResult.clienteId;

          // 2. Crear transacción en Transbank
          const paymentResponse = await fetch('/api/transbank/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              amount: 50,
              orderId: clienteId,
              clienteId: clienteId
            })
          });

          const paymentData = await paymentResponse.json();

          if (paymentData.success && paymentData.url && paymentData.token) {
            // 3. Redirigir a Webpay
            const webpayForm = document.createElement('form');
            webpayForm.method = 'POST';
            webpayForm.action = paymentData.url;

            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = 'token_ws';
            tokenInput.value = paymentData.token;

            webpayForm.appendChild(tokenInput);
            document.body.appendChild(webpayForm);
            webpayForm.submit();
          } else {
            throw new Error(paymentData.error || 'Error al procesar pago');
          }
        } catch (error) {
          console.error('Error:', error);
          alert(`Error: ${error instanceof Error ? error.message : 'Intenta nuevamente'}`);
          button.textContent = 'PROCEDER AL PAGO';
          button.removeAttribute('disabled');
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('checkout-form') as HTMLFormElement;
        if (form) {
          form.addEventListener('submit', handleCheckout);
        }

        // Manejo del modal de términos
        const btnTerminos = document.getElementById('btn-terminos');
        const modalTerminos = document.getElementById('modal-terminos') as HTMLDialogElement;
        const btnCerrarTerminos = document.getElementById('btn-cerrar-terminos');

        if (btnTerminos && modalTerminos) {
          btnTerminos.addEventListener('click', (e) => {
            e.preventDefault();
            modalTerminos.showModal();
          });
        }

        if (btnCerrarTerminos && modalTerminos) {
          btnCerrarTerminos.addEventListener('click', () => {
            modalTerminos.close();
          });
        }

        // Cerrar modal al hacer clic afuera
        if (modalTerminos) {
          modalTerminos.addEventListener('click', (e) => {
            if (e.target === modalTerminos) {
              modalTerminos.close();
            }
          });
        }
      });
    </script>

    <!-- Modal de Términos y Condiciones -->
    <dialog id="modal-terminos" class="rounded-lg shadow-lg p-0 max-w-2xl w-11/12">
      <div class="bg-white p-8 max-h-[80vh] overflow-y-auto">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-[#989086]">Términos y Condiciones</h2>
          <button type="button" id="btn-cerrar-terminos" class="text-gray-400 hover:text-gray-600 text-2xl">×</button>
        </div>

        <div class="text-[#989086] text-sm leading-relaxed space-y-4">
          <p>Bienvenido(a) a Pilates Malú Pérez. Los Términos y Condiciones que te mostraremos a continuación regulan el acceso en Chile a nuestro sitio www.pilatesmaluperez.cl y su uso por parte de todos los usuarios o consumidores. En este sitio podrás usar,  con costo asociado, para la asistencia y/o participación en el Estudio ubicado en Nueva Costanera 3900, Vitacura, local 2056B, además de productos o servicios que se encuentren en la web.Te recomendamos leerlos atentamente para que sepas en qué consisten y no tengas dudas luego de navegar o comprar con nosotros.</p>

          <p>Estos Términos y Condiciones aplicarán y se entenderán incorporados en todas las compras que contrates con Pilates Malú Pérez. Mediante los sistemas de comercialización comprendidos en este sitio web. Esos contratos, el uso del sitio y la aplicación de estos Términos y Condiciones están sujetos a las leyes de la República de Chile; especialmente las que protegen los derechos de los consumidores, sin renunciar a los derechos y acciones que otorgan estas leyes. En consecuencia, gozarás de todos los derechos que reconoce la ley chilena y los que te otorgan estos términos y condiciones.</p>

          <p>En nuestro sitio podrás acceder a información de clases, planes, servicios y contacto. El objetivo es facilitar el acceso e incrementar los beneficios de uso, que pueden variar periódicamente, sin afectar, en caso alguno los derechos adquiridos por los consumidores.Pilates Malú Pérez aplicará estrictamente todos los beneficios y garantías que la Ley sobre Protección de los Derechos de los Consumidores establece para las transacciones que se realizan a través de su sitio. Adicionalmente, www.pilatesmaluperez.cl adhiere en todas sus partes el Código de Buenas Prácticas para el Comercio Electrónico de la Cámara de Comercio de Santiago.</p>

          <p>También, contamos con todas las leyes y normas de protección de datos al usuario.
Cualquier duda o consulta contactar a hola@pilatesmaluperez.cl</p>

          <p>No se realizará devolución de dinero por problemáticas del usuarios ni situaciones externas a los servicios propios de Pilates Malú Pérez</p>

          <p>Congelamiento exclusivo en planes Trimestrales o de mayor tiempo.</p>

          <p>Las consecuencias/derivaciones y acciones que se obtengan por resultado de los servicios entregados por Pilates Malú Pérez son 100% responsabilidad del usuario y/o consumidor y en ningún caso son estipulables de dolo.</p>

          <p>Reiteramos nuestro compromiso con tus datos, por lo cual, te informamos de tus derechos respecto al tema:
Puedes revocar en cualquier momento la autorización que entregas para tratar tus Datos Personales, en cuyo caso es posible que no puedas utilizar alguno o todos los servicios o beneficios que ofrece Pilates Malú Pérez. Es tu derecho pedirnos información sobre los Datos Personales tuyos que hayamos recolectado y ejercer tus derechos de rectificación, cancelación, oposición. y todos los demás derechos que confiere la Ley N° 19.628 sobre Protección de la Vida Privada. Para ejercer estos derechos sólo deberás contactarnos a hola@pilatesmaluperez.cl</p>

          <p class="font-semibold">¡En Pilates Malú Pérez eres lo más importante!!</p>
        </div>
      </div>
    </dialog>

    <!-- Footer Section -->
    <footer class="bg-[#A1998D] w-full py-10">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-row items-center justify-between flex-nowrap gap-8" style="min-height:120px">
          <!-- Logo -->
          <div class="flex-shrink-0 flex items-center justify-center" style="min-width:120px">
            <img src="/fonts/Logo-Malu-Perez-Final-Footer.png" alt="Malú Pérez" class="h-24 w-24 object-contain rounded-full bg-[#A1998D] p-2 border-0" />
          </div>
          <!-- Instagram -->
          <div class="flex flex-col items-center flex-grow text-center">
            <svg class="w-12 h-12 text-white mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <rect width="20" height="20" x="2" y="2" rx="5" stroke="currentColor" stroke-width="2"/>
              <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>
            </svg>
            <span class="text-white font-light">Síguenos en</span>
            <span class="text-white font-semibold">@pilatesmaluperez</span>
          </div>

          <!-- Location -->
          <div class="flex flex-col items-end flex-shrink-0 text-right" style="min-width:220px">
            <svg class="w-12 h-12 text-white mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white font-light">Mall Casa Costanera,</span>
            <span class="text-white font-light">Av. Nueva Costanera 3900,</span>
            <span class="text-white font-light">Vitacura, 3er Piso</span>
          </div>
        </div>
      </div>
      <style>
        @media (max-width: 900px) {
          footer .flex-row { gap: 2rem; }
          footer .flex-col { font-size: 0.95rem; }
        }
        @media (max-width: 700px) {
          footer .flex-row { gap: 1rem; }
          footer .flex-col { font-size: 0.9rem; }
          footer .w-12, footer .h-12 { width: 2.5rem; height: 2.5rem; }
          footer .h-24, footer .w-24 { height: 4rem; width: 4rem; }
        }
        @media (max-width: 600px) {
          footer .flex-row { gap: 0.5rem; }
          footer .flex-col { font-size: 0.85rem; }
