---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen w-full">
    <script>
      async function handleTestPayment() {
        const button = document.getElementById('btn-test-50');
        if (!button) return;

        // Deshabilitar botón
        button.textContent = 'Procesando...';
        button.setAttribute('disabled', 'true');

        try {
          const response = await fetch('/api/transbank/create', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              amount: 50,
              orderId: `TST${Date.now().toString().slice(-10)}`
            })
          });

          const data = await response.json();

          if (data.success && data.url && data.token) {
            // Crear formulario para redireccionar a Webpay
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = data.url;

            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'token_ws';
            input.value = data.token;

            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
          } else {
            throw new Error(data.error || 'Error al procesar el pago');
          }
        } catch (error) {
          console.error('Error:', error);
          alert('Error al procesar el pago de prueba: ' + error.message);
          button.textContent = 'PAGAR $50 (PRUEBA)';
          button.removeAttribute('disabled');
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        const button = document.getElementById('btn-test-50');
        if (button) {
          button.addEventListener('click', handleTestPayment);
        }
      });
    </script>

    <!-- Header Section -->
    <div class="bg-[#989086] py-2 md:py-3">
      <div class="text-center">
        <h1 class="text-3xl md:text-4xl tracking-[0.4em] font-light text-white mb-0">PILATES</h1>
        <p class="text-xs md:text-sm tracking-[0.4em] font-light text-white mt-0">MALÚ PÉREZ</p>
      </div>
    </div>

    <!-- Contenido de Prueba -->
    <section class="w-full flex flex-col items-center justify-center py-16 px-4 bg-white">
      <div class="max-w-3xl w-full">
        <!-- Alerta de Prueba -->
        <div class="bg-yellow-100 border-l-4 border-yellow-500 p-6 mb-8">
          <div class="flex items-start">
            <svg class="w-6 h-6 text-yellow-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
            <div>
              <h3 class="text-lg font-bold text-yellow-800 mb-2">⚠️ PÁGINA DE PRUEBA - SOLO PARA VALIDACIÓN TRANSBANK</h3>
              <p class="text-yellow-700 text-sm">
                Esta página es exclusivamente para validar la integración con Transbank. 
                <strong>ELIMINAR después de recibir aprobación.</strong>
              </p>
            </div>
          </div>
        </div>

        <!-- Card de Prueba -->
        <div class="bg-[#EDE8E3] rounded-3xl shadow-lg p-8 md:p-12">
          <div class="text-center mb-8">
            <h2 class="text-3xl md:text-4xl font-bold text-[#989086] mb-4">
              Transacción de Validación
            </h2>
            <p class="text-[#989086] text-lg mb-2">
              Monto requerido por Transbank para aprobar el pase a producción
            </p>
          </div>

          <!-- Monto -->
          <div class="bg-white rounded-xl p-8 mb-8 text-center">
            <div class="text-[#989086] text-6xl font-bold mb-4">$50</div>
            <p class="text-[#989086] text-sm">Pesos Chilenos (CLP)</p>
          </div>

          <!-- Instrucciones -->
          <div class="bg-[#D4CCC3] rounded-xl p-6 mb-8">
            <h3 class="text-[#989086] font-bold text-lg mb-3">📋 Instrucciones:</h3>
            <ol class="text-[#989086] text-sm space-y-2 list-decimal list-inside">
              <li>Haz clic en el botón "PAGAR $50"</li>
              <li>Serás redirigido a Webpay (Transbank)</li>
              <li>Completa el pago con tu tarjeta REAL</li>
              <li>Se descontarán $50 de tu cuenta</li>
              <li>Captura pantalla del comprobante exitoso</li>
              <li>Verifica que aparezca el descuento en tu banco</li>
            </ol>
          </div>

          <!-- Datos de Tarjeta de Prueba (solo integración) -->
          <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 mb-8">
            <h3 class="text-blue-800 font-bold text-lg mb-3">🔧 Para Ambiente de Integración:</h3>
            <div class="text-blue-700 text-sm space-y-1">
              <p><strong>Tarjeta:</strong> 4051 8856 0044 6623</p>
              <p><strong>CVV:</strong> 123</p>
              <p><strong>Fecha:</strong> Cualquier fecha futura</p>
              <p><strong>RUT:</strong> 11.111.111-1</p>
              <p><strong>Clave:</strong> 123</p>
            </div>
            <p class="text-blue-600 text-xs mt-3">
              ⚠️ En PRODUCCIÓN usa tu tarjeta real. Los $50 se cobrarán de verdad.
            </p>
          </div>

          <!-- Botón de Pago -->
          <div class="text-center">
            <button 
              id="btn-test-50"
              class="bg-[#989086] text-white font-bold text-xl px-12 py-4 rounded-full hover:bg-[#B4A79D] transition disabled:opacity-50 disabled:cursor-not-allowed shadow-lg"
            >
              PAGAR $50 (PRUEBA)
            </button>
          </div>

          <!-- Nota Final -->
          <div class="mt-8 p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="text-red-700 text-sm text-center">
              <strong>IMPORTANTE:</strong> Una vez validado por Transbank, elimina esta página completamente del código.
            </p>
          </div>
        </div>

        <!-- Botón Volver -->
        <div class="text-center mt-8">
          <a 
            href="/" 
            class="inline-block text-[#989086] hover:text-[#B4A79D] font-semibold underline"
          >
            ← Volver al Inicio
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
