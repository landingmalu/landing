# Transbank Configuration
# IMPORTANTE: Este archivo es solo ejemplo. NO subir .env a Git.

# ========================================
# AMBIENTE DE INTEGRACIÓN (PRUEBAS)
# ========================================
# Usa estos valores para probar localmente con tarjetas de prueba de Transbank
# TBK_API_KEY_ID=597055555532
# TBK_API_KEY_SECRET=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
# TBK_ENVIRONMENT=INTEGRATION

# ========================================
# AMBIENTE DE PRODUCCIÓN
# ========================================
# Para producción, reemplaza con tus credenciales REALES de Transbank
# NUNCA compartas estas credenciales públicamente
TBK_API_KEY_ID=tu_codigo_597_aqui
TBK_API_KEY_SECRET=tu_codigo_93d_aqui
TBK_ENVIRONMENT=PRODUCTION

# URL base de tu sitio (CRÍTICO para Transbank)
# En desarrollo local:
# PUBLIC_BASE_URL=http://localhost:4321
# En producción (DEBE ser HTTPS):
PUBLIC_BASE_URL=https://tudominio.cl

# Puerto para desarrollo local (opcional)
PORT=4321

# Supabase Configuration
PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu_password_seguro_aqui
